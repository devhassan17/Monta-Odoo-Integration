<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sale_order_portal_content_monta_tracking" name="Monta Tracking" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//div[@id='introduction']" position="after">
            <div t-if="sale_order.monta_tracking_url" class="mt-3 p-3 border rounded bg-light" id="monta_tracking_info">
                <strong class="d-block mb-1">Track &amp; Trace</strong>
                <a t-att-href="sale_order.monta_tracking_url" target="_blank" class="btn btn-primary btn-sm">
                    <i class="fa fa-truck me-1"/> View Delivery Status
                </a>
            </div>
        </xpath>
    </template>
</odoo>
