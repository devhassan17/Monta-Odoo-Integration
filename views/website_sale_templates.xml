<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="monta_pickup_widget_inject" inherit_id="website_sale.checkout" name="Monta Delivery Options &amp; Pickup Point Injection">
        <xpath expr="//t[@t-call='website_sale.billing_address_row']" position="before">
            <t t-if="website_sale_order and 'monta_shipper_code' in website_sale_order._fields">
                <div class="monta-delivery-container mt-3 mb-4 p-3 border rounded bg-white shadow-sm">
                    <h6 class="fw-bold mb-3" style="color: #E5007D;">
                        <i class="fa fa-truck me-1"/> Select Delivery Speed &amp; Options
                    </h6>
                    
                    <!-- Delivery Method / Speed Selectors -->
                    <div class="monta-delivery-type-options d-flex flex-wrap gap-2 mb-3">
                        <label class="monta-delivery-option-card flex-fill p-2 border rounded text-center cursor-pointer" t-att-class="'active' if (website_sale_order.monta_delivery_type or 'standard') == 'standard' else ''">
                            <input type="radio" name="monta_delivery_type" value="standard" class="d-none" t-att-checked="'checked' if (website_sale_order.monta_delivery_type or 'standard') == 'standard' else None"/>
                            <div class="fw-bold small text-dark"><i class="fa fa-box me-1"/> Standard</div>
                            <div class="text-muted extra-small">Regular fulfillment</div>
                        </label>
                        <label class="monta-delivery-option-card flex-fill p-2 border rounded text-center cursor-pointer" t-att-class="'active' if website_sale_order.monta_delivery_type == 'next_day' else ''">
                            <input type="radio" name="monta_delivery_type" value="next_day" class="d-none" t-att-checked="'checked' if website_sale_order.monta_delivery_type == 'next_day' else None"/>
                            <div class="fw-bold small text-dark"><i class="fa fa-bolt me-1 text-warning"/> Next Day</div>
                            <div class="text-muted extra-small">Delivered tomorrow</div>
                        </label>
                        <label class="monta-delivery-option-card flex-fill p-2 border rounded text-center cursor-pointer" t-att-class="'active' if website_sale_order.monta_delivery_type == 'two_day' else ''">
                            <input type="radio" name="monta_delivery_type" value="two_day" class="d-none" t-att-checked="'checked' if website_sale_order.monta_delivery_type == 'two_day' else None"/>
                            <div class="fw-bold small text-dark"><i class="fa fa-calendar me-1 text-info"/> 1-Day</div>
                            <div class="text-muted extra-small">Delivered in 1 day</div>
                        </label>
                        <label class="monta-delivery-option-card flex-fill p-2 border rounded text-center cursor-pointer" t-att-class="'active' if (website_sale_order.monta_delivery_type == 'pickup' or website_sale_order.monta_shipper_code) else ''">
                            <input type="radio" name="monta_delivery_type" value="pickup" id="monta_use_pickup" class="d-none" t-att-checked="'checked' if (website_sale_order.monta_delivery_type == 'pickup' or website_sale_order.monta_shipper_code) else None"/>
                            <div class="fw-bold small" style="color: #E5007D;"><i class="fa fa-map-marker me-1"/> Delivery Point</div>
                            <div class="text-muted extra-small">Pickup location</div>
                        </label>
                    </div>

                    <!-- Pickup Point Search Box -->
                    <div id="monta-pickup-box" class="collapse mt-3 pt-3 border-top" t-att-class="'show' if (website_sale_order.monta_delivery_type == 'pickup' or website_sale_order.monta_shipper_code) else ''">
                        <div class="text-muted small mb-2"><i class="fa fa-info-circle me-1"/> Search pickup points near your address:</div>
                        <div class="row g-2 mb-3">
                            <div class="col-md-5">
                                <input type="text" id="monta_pickup_street" class="form-control form-control-sm border-secondary" placeholder="Street Name" t-att-value="website_sale_order.partner_shipping_id.street or website_sale_order.partner_id.street or ''"/>
                            </div>
                            <div class="col-md-3">
                                <input type="text" id="monta_pickup_house" class="form-control form-control-sm border-secondary" placeholder="House #" t-att-value="website_sale_order.partner_shipping_id.street2 or website_sale_order.partner_id.street2 or ''"/>
                            </div>
                            <div class="col-md-4">
                                <input type="text" id="monta_pickup_zip" class="form-control form-control-sm border-secondary" placeholder="Zip Code" t-att-value="website_sale_order.partner_shipping_id.zip or website_sale_order.partner_id.zip or ''"/>
                            </div>
                            <div class="col-md-5">
                                <input type="text" id="monta_pickup_city" class="form-control form-control-sm border-secondary" placeholder="City" t-att-value="website_sale_order.partner_shipping_id.city or website_sale_order.partner_id.city or ''"/>
                            </div>
                            <div class="col-md-4">
                                <select id="monta_pickup_country" class="form-select form-select-sm border-secondary">
                                    <option value="NL" t-att-selected="'selected' if (website_sale_order.partner_shipping_id.country_id.code or website_sale_order.partner_id.country_id.code or 'NL') == 'NL' else None">Netherlands</option>
                                    <option value="BE" t-att-selected="'selected' if (website_sale_order.partner_shipping_id.country_id.code or website_sale_order.partner_id.country_id.code) == 'BE' else None">Belgium</option>
                                    <option value="DE" t-att-selected="'selected' if (website_sale_order.partner_shipping_id.country_id.code or website_sale_order.partner_id.country_id.code) == 'DE' else None">Germany</option>
                                    <option value="GB" t-att-selected="'selected' if (website_sale_order.partner_shipping_id.country_id.code or website_sale_order.partner_id.country_id.code) == 'GB' else None">United Kingdom</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <button type="button" id="btn_search_monta_pickup" class="btn btn-sm w-100 text-white fw-bold" style="background-color: #E5007D; border-color: #E5007D;">
                                    <i class="fa fa-search me-1"/> Search
                                </button>
                            </div>
                        </div>
                        
                        <div id="monta_pickup_loading" class="text-center d-none my-4">
                            <div class="spinner-border spinner-border-sm" role="status" style="color: #E5007D;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                        
                        <div id="monta_pickup_error" class="alert alert-danger d-none py-2 px-3 small" role="alert">
                        </div>
                        
                        <div id="monta_pickup_results" class="monta-pickup-list d-flex flex-column gap-2" style="max-height: 380px; overflow-y: auto;">
                            <!-- Dynamically loaded pickup point cards -->
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
