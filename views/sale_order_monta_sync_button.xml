<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_order_form_monta_sync_inherit" model="ir.ui.view">
      <field name="name">sale.order.monta.sync.inherit</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
        <xpath expr="//form/header" position="inside">
          <button name="action_monta_sync_status"
                  type="object"
                  string="Sync Monta"
                  class="btn-primary"
                  invisible="state in ['draft', 'cancel']"/>
          <button name="action_open_monta_order_status"
                  type="object"
                  class="oe_stat_button"
                  icon="fa-truck">
            <div class="o_stat_info">
              <span class="o_stat_text">Monta Status</span>
            </div>
          </button>
        </xpath>
        <xpath expr="//notebook" position="inside">
          <page string="Monta Shipping Options" name="monta_shipping_options">
            <group>
              <group string="Delivery Speed &amp; Options">
                <field name="monta_delivery_type" widget="radio"/>
                <field name="monta_requested_delivery_date"/>
                <field name="monta_shipper_code" readonly="1"/>
              </group>
              <group string="Monta Status &amp; Tracking">
                <field name="monta_status" readonly="1"/>
                <field name="monta_delivery_status" readonly="1"/>
                <field name="monta_status_code" readonly="1"/>
                <field name="monta_track_trace" widget="url" readonly="1"/>
              </group>
            </group>
          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
