<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!--
        Monta Subscription Delivery Sync Cron
        ======================================
        DISABLED: Delivery is now triggered directly from account.move.action_post()
        when Odoo's native subscription renewal cron posts a renewal invoice.

        The Odoo default cron "Sale Subscription: Generate Recurring Invoices"
        is the only cron needed.  This record is kept with active=False so
        existing installations don't break on module upgrade.
    -->
    <record id="ir_cron_monta_subscription_delivery_sync" model="ir.cron">
      <field name="name">Monta: Subscription Renewal Delivery Sync (Disabled)</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="state">code</field>
      <field name="code">model._cron_monta_subscription_delivery_sync()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">hours</field>
      <field name="active">False</field>
      <field name="user_id" ref="base.user_root"/>
    </record>

  </data>
</odoo>
